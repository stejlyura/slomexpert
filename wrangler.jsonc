{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "slomexpert",
  "compatibility_date": "2024-04-24",
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  }
}
